# LANEs_CEO Configuration
# Copy this file to .env and fill in your values.

# Core paths
LANES_CEO_DB_PATH=runtime/lanes_ceo.sqlite3
LANES_CEO_TIMEZONE=Asia/Shanghai
LANES_CEO_ARTIFACT_DIR=runtime/artifacts
LANES_CEO_LOG_LEVEL=INFO
LANES_CEO_LOG_FILE=runtime/lanes_ceo.log
# Output base for generated files (.docx, .pptx, etc.), organized by content type
LANES_CEO_OUTPUT_BASE=G:/blog/claude_code_useage/PROJECT/multi-agent

# LLM (OpenAI-compatible API)
LANES_CEO_LLM_PROVIDER=openai
LANES_CEO_LLM_API_KEY=sk-your-api-key
LANES_CEO_LLM_BASE_URL=https://api.openai.com/v1
LANES_CEO_LLM_MODEL=gpt-4o

# DeepSeek balance monitoring
LANES_CEO_DEEPSEEK_BALANCE_THRESHOLD=10.0
LANES_CEO_DEEPSEEK_API_KEY=

# Feishu (Lark) bot channel — enables messaging via Feishu group chat
LANES_CEO_FEISHU_ENABLED=false
LANES_CEO_FEISHU_APP_ID=
LANES_CEO_FEISHU_APP_SECRET=
LANES_CEO_FEISHU_WEBHOOK_HOST=127.0.0.1
LANES_CEO_FEISHU_WEBHOOK_PORT=8080

# Weixin notification channel
LANES_CEO_WEIXIN_ENABLED=false

# QQ notification channel
LANES_CEO_QQ_ENABLED=false

# Email notification channel
LANES_CEO_EMAIL_ENABLED=false
LANES_CEO_EMAIL_ADDRESS=
LANES_CEO_EMAIL_PASSWORD=
LANES_CEO_EMAIL_IMAP_SERVER=
LANES_CEO_EMAIL_SMTP_SERVER=

# Default notification channel (cli, feishu, weixin, qq, email)
LANES_CEO_NOTIFICATION_CHANNEL=cli
