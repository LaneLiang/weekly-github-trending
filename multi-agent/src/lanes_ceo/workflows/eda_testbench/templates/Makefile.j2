# Auto-generated by LANEs_CEO eda_testbench
# DUT: {{ top_entity }}
# Tool: ModelSim/Questa + cocotb

# ── cocotb configuration ──
export COCOTB_REDUCED_LOG_FMT=1

TOPLEVEL_LANG ?= verilog
{% if dut_file %}
{% if dut_file.startswith('/') or ':' in dut_file %}
VERILOG_SOURCES := {{ dut_file }}
{% else %}
VERILOG_SOURCES := $(CURDIR)/{{ dut_file }}
{% endif %}
{% else %}
VERILOG_SOURCES := $(CURDIR)/{{ top_entity }}.v
{% endif %}
TOPLEVEL := {{ top_entity }}
MODULE := {{ tb_module_name }}

# ── simulation tool ──
SIM ?= questa

# ── waveform dump ──
{% if sim.vcd_dump %}
EXTRA_ARGS += +vcd
{% endif %}

# ── coverage ──
{% if coverage.enabled %}
EXTRA_ARGS += +cover=sbceft
export COVERAGE := 1
{% endif %}

# ── compile args ──
COMPILE_ARGS += +acc
EXTRA_ARGS += -voptargs=+acc

# ── timescale ──
COMPILE_ARGS += -timescale 1ns/10ps

# ── include paths (add user paths below) ──
# COMPILE_ARGS += -I$(CURDIR)/include

include $(shell cocotb-config --makefiles)/Makefile.sim

# ── coverage report target ──
{% if coverage.enabled %}
.PHONY: coverage_report
coverage_report:
	vcover report -details -html merged.ucdb
	@echo "Coverage report generated: ./coverage_report/index.html"
{% endif %}

# ── clean ──
.PHONY: clean_all
clean_all: clean
	rm -rf sim_build *.ucdb coverage_report *.vcd transcript *.wlf 2>/dev/null; true
